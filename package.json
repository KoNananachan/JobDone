{
  "name": "jobdone",
  "version": "0.1.0",
  "description": "A floating, always-on-top todo widget for macOS that makes shipping feel good.",
  "main": "electron/main.cjs",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "KoNananachan",
    "url": "https://github.com/KoNananachan"
  },
  "homepage": "https://github.com/KoNananachan/JobDone#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KoNananachan/JobDone.git"
  },
  "bugs": {
    "url": "https://github.com/KoNananachan/JobDone/issues"
  },
  "keywords": [
    "todo",
    "todolist",
    "task-manager",
    "macos",
    "menubar",
    "floating-window",
    "always-on-top",
    "productivity",
    "electron",
    "react"
  ],
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5180 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "pack": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "make-icon": "electron scripts/make-icon.cjs"
  },
  "build": {
    "appId": "com.jobdone.app",
    "productName": "JobDone",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!dist/mac-arm64/**",
      "!dist/builder-debug.yml"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dir", "arch": ["arm64", "x64"] }],
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
