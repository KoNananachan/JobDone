{
  "name": "jobdone",
  "version": "0.2.0",
  "description": "A floating, always-on-top todo widget for macOS that makes shipping feel good.",
  "main": "electron/main.cjs",
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": {
    "name": "KoNananachan",
    "url": "https://github.com/KoNananachan"
  },
  "homepage": "https://github.com/KoNananachan/JobDone#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KoNananachan/JobDone.git"
  },
  "bugs": {
    "url": "https://github.com/KoNananachan/JobDone/issues"
  },
  "keywords": [
    "todo",
    "todolist",
    "task-manager",
    "macos",
    "menubar",
    "floating-window",
    "always-on-top",
    "productivity",
    "electron",
    "react"
  ],
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5180 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "pack": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:mac": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --x64",
    "dist:win": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --arm64",
    "make-icons": "electron scripts/make-icons.cjs"
  },
  "build": {
    "appId": "com.jobdone.app",
    "productName": "JobDone",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!dist/mac-arm64/**",
      "!dist/builder-debug.yml"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      },
      "artifactName": "JobDone-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "JobDone ${version}",
      "icon": "build/icon.icns",
      "iconSize": 96,
      "contents": [
        { "x": 130, "y": 200, "type": "file" },
        { "x": 410, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "artifactName": "JobDone-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JobDone",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "JobDone-${version}-win-${arch}-portable.${ext}"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
